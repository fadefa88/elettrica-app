{
  "name": "elettrica-o-termica",
  "version": "1.0.0",
  "description": "Calcolatore convenienza auto elettrica o termica per web e iOS Capacitor.",
  "private": true,
  "scripts": {
    "build": "node scripts/build-ios-web.js",
    "build:ios-web": "node scripts/build-ios-web.js",
    "cap:add:ios": "npx cap add ios",
    "cap:sync:ios": "npm run build:ios-web && npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "cap:doctor": "npx cap doctor"
  },
  "keywords": [
    "auto elettrica",
    "auto termica",
    "tco",
    "convenienza auto elettrica",
    "capacitor",
    "ios"
  ],
  "author": "Elettrica o Termica",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.4.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "typescript": "^5.8.3"
  }
}
